# .env.example — starter environment file for projects adopting claude_template_yaml.
#
# Copy this to .env (gitignored) and fill in the values. The Strategist owns
# this file — values are confirmed during the first-contact interview, per
# docs/dev_framework/strategist.md §"First-contact interview".
#
# .env is the canonical source of truth for machine-readable project variables.
# CLAUDE.md displays the same values inline for human readers — keep them in
# sync. Scripts (setup_dev_slots.sh, future helpers) source this file rather
# than parsing CLAUDE.md, so values here are what tooling actually sees.
#
# Lines marked PLACEHOLDER must be replaced before scripts that consume them
# will run. setup_dev_slots.sh halts on PLACEHOLDER values for PROJECT_SUB
# and PROJECT_PORTS (per ADR-019 Revision v1.1).

# =============================================================================
# Project identity
# =============================================================================

# Project name (machine-safe slug; lowercase, hyphens or underscores OK).
# Example: PROJECT_NAME=auto-portal
PROJECT_NAME=PLACEHOLDER

# Project subdomain — the <sub> in URLs like <slot>.<sub>.localhost (dev) and
# <sub>.<website>.com (prod). Short, lowercase.
# Example: PROJECT_SUB=auto
PROJECT_SUB=PLACEHOLDER

# Parent domain — the <website> in <sub>.<website>.com. Bare domain, no scheme.
# Example: PROJECT_WEBSITE=jumpermedia.co
PROJECT_WEBSITE=PLACEHOLDER

# Port range allocated to this project — used by setup_dev_slots.sh to pick
# slot ports and (if HTTP surface) configure Caddy reverse-proxy blocks.
# Format: <low>-<high>. Need at least 4 contiguous ports for dev slots.
# Strategist confirms with the user to avoid collisions with other projects
# on the same machine. Example: PROJECT_PORTS=3050-3060
PROJECT_PORTS=PLACEHOLDER

# Dev environment mode — local-hosted (dev on user's machine) or
# remote-hosted (dev on a shared server). See docs/architecture/adr-011-dev-environment.md
# once that ADR is accepted.
# Example: DEV_ENVIRONMENT_MODE=local-hosted
DEV_ENVIRONMENT_MODE=PLACEHOLDER

# =============================================================================
# Split layout (ADR-021)
# =============================================================================

# Name of the subdirectory holding the primary code repo. Matches the GitHub
# repo slug exactly. Used by the Developer (cd $PROJECT_DIR/$DEFAULT_CODE_SUBDIR
# at bootstrap) and by sync-framework.sh (subdir .env scan fallback).
# Example: DEFAULT_CODE_SUBDIR=auto-jm-co
DEFAULT_CODE_SUBDIR=PLACEHOLDER

# Path to the canonical claude_template_yaml repo on this machine. Optional —
# if unset, sync-framework.sh falls back to sibling-directory search
# (../claude_template_yaml, ../../claude_template_yaml, ../../../claude_template_yaml).
# Example: CLAUDE_TEMPLATE_ROOT=/Users/you/code/claude_template_yaml
# CLAUDE_TEMPLATE_ROOT=

# =============================================================================
# Runtime secrets / project-specific (fill as your project requires)
# =============================================================================
# DATABASE_URL=...
# API_KEY=...
# (add what your application needs; this section is not framework-managed)
